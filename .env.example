# ─────────────────────────────────────────────────────────
# .env.example — このファイルをコピーして .env を作成してください
# cp .env.example .env
# ─────────────────────────────────────────────────────────

# GitHub Pages のユーザー名（astro.config.mjs の site URL に使用）
GITHUB_USERNAME=

# 楽天アフィリエイトID（src/data/products.ts の rakutenUrl に使用）
RAKUTEN_AFFILIATE_ID=

# 楽天 Web Service Application ID（商品検索API に使用）
# 取得: https://webservice.rakuten.co.jp/
RAKUTEN_APPLICATION_ID=

# 楽天 Web Service アクセスキー（商品検索API に使用）
RAKUTEN_ACCESS_KEY=
