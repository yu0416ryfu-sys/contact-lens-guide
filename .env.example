# GitHub Pages のユーザー名（astro.config.mjs の site URL に使用）
GITHUB_USERNAME=

# 楽天アフィリエイトID（src/data/products.ts の rakutenUrl に使用）
RAKUTEN_AFFILIATE_ID=
