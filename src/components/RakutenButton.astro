---
interface Props {
  url: string;
  label?: string;
  size?: 'sm' | 'md' | 'lg';
  fullWidth?: boolean;
}

const {
  url,
  label = '楽天市場で見る',
  size = 'md',
  fullWidth = false,
} = Astro.props;

const sizeClass = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg',
}[size];
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer sponsored"
  class:list={[
    'inline-flex items-center justify-center gap-2 font-bold rounded-lg',
    'bg-rakuten hover:bg-rakuten-dark active:bg-rakuten-dark',
    'text-white transition-all duration-150',
    'shadow-md hover:shadow-lg active:shadow-sm active:translate-y-px',
    sizeClass,
    fullWidth ? 'w-full' : '',
  ]}
>
  <!-- 楽天ロゴ風マーク -->
  <svg
    class="w-5 h-5 flex-shrink-0"
    viewBox="0 0 24 24"
    fill="currentColor"
    aria-hidden="true"
  >
    <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm-1 14H9V8h2v8zm4 0h-2v-5.5L11 12V8h2v3l2-1.5V16z" />
  </svg>
  {label}
  <svg
    class="w-4 h-4 flex-shrink-0"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
  </svg>
</a>
