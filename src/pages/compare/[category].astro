---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RakutenButton from '../../components/RakutenButton.astro';
import StarRating from '../../components/StarRating.astro';
import { getCategoryInfo } from '../../data/categories';
import { getProductsByCategory } from '../../data/products';
import type { CategoryId } from '../../types/index';

export function getStaticPaths() {
  return ['oneday', 'twoweek', 'color', 'toric', 'multifocal'].map(id => ({
    params: { category: id },
  }));
}

const { category } = Astro.params as { category: CategoryId };
const categoryInfo = getCategoryInfo(category)!;
const products = getProductsByCategory(category);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title={`${categoryInfo.name}コンタクト 徹底比較表`}
  description={`${categoryInfo.name}コンタクトレンズ${products.length}商品を一覧表で徹底比較。価格・含水率・UVカット・BC・DIA・素材など全スペックを横並びで確認できます。`}
>
  <!-- パンくず -->
  <nav class="bg-white border-b border-gray-100 py-2 px-4 text-sm" aria-label="パンくずリスト">
    <ol class="max-w-6xl mx-auto flex flex-wrap items-center gap-2 text-gray-500">
      <li><a href={`${base}/`} class="hover:text-blue-600 transition-colors">ホーム</a></li>
      <li aria-hidden="true">›</li>
      <li>
        <a href={`${base}/category/${category}/`} class="hover:text-blue-600 transition-colors">
          {categoryInfo.name}
        </a>
      </li>
      <li aria-hidden="true">›</li>
      <li class="text-gray-900 font-medium">比較表</li>
    </ol>
  </nav>

  <!-- ヘッダー -->
  <section class:list={['py-8 px-4', categoryInfo.bgColor]}>
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-4xl" aria-hidden="true">{categoryInfo.icon}</span>
        <h1 class:list={['text-2xl md:text-3xl font-extrabold', categoryInfo.textColor]}>
          {categoryInfo.name}コンタクト 徹底比較
        </h1>
      </div>
      <p class="text-gray-600">
        {products.length}商品のスペックを一覧表で比較。価格・含水率・UVカットなど全項目を横並びで確認できます。
      </p>
    </div>
  </section>

  <!-- 比較テーブル -->
  <section class="py-8 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="overflow-x-auto rounded-2xl shadow-sm border border-gray-200 bg-white">
        <table class="min-w-full text-sm">
          <!-- ヘッダー行：商品名 -->
          <thead>
            <tr class="border-b-2 border-gray-200">
              <th scope="col" class="sticky left-0 z-10 bg-gray-50 text-left px-4 py-3 text-gray-600 font-semibold whitespace-nowrap border-r border-gray-200 min-w-[140px]">
                項目 / 商品
              </th>
              {products.map(product => (
                <th scope="col" class="px-4 py-3 text-center min-w-[180px] font-normal">
                  <a
                    href={`${base}/products/${product.slug}/`}
                    class="font-bold text-blue-800 hover:text-blue-600 transition-colors leading-snug block"
                  >
                    {product.name}
                  </a>
                  <span class="text-xs text-gray-400">{product.brand}</span>
                </th>
              ))}
            </tr>
          </thead>

          <tbody>
            <!-- 商品画像 -->
            <tr class="border-b border-gray-100 bg-white">
              <th scope="row" class="sticky left-0 z-10 bg-white text-left px-4 py-3 text-gray-600 font-medium whitespace-nowrap border-r border-gray-200">
                画像
              </th>
              {products.map(product => (
                <td class="px-4 py-3 text-center">
                  <a href={`${base}/products/${product.slug}/`}>
                    <img
                      src={product.image}
                      alt={product.name}
                      width="120"
                      height="90"
                      loading="lazy"
                      class="w-28 h-20 object-cover rounded-lg mx-auto hover:opacity-80 transition-opacity"
                    />
                  </a>
                </td>
              ))}
            </tr>

            <!-- 価格 -->
            <tr class="border-b border-gray-100 bg-blue-50/30">
              <th scope="row" class="sticky left-0 z-10 bg-blue-50/60 text-left px-4 py-3 text-gray-600 font-medium whitespace-nowrap border-r border-gray-200">
                価格（1箱）
              </th>
              {products.map(product => {
                const minPrice = Math.min(...products.map(p => p.price));
                return (
                  <td class="px-4 py-3 text-center">
                    <span class:list={[
                      'text-xl font-extrabold',
                      product.price === minPrice ? 'text-green-700' : 'text-blue-800',
                    ]}>
                      ¥{product.price.toLocaleString()}
                    </span>
                    <br />
                    <span class="text-xs text-gray-500">/ {product.boxCount}枚</span>
                    {product.price === minPrice && (
                      <span class="block text-xs font-bold text-green-600 mt-0.5">💰 最安値</span>
                    )}
                  </td>
                );
              })}
            </tr>

            <!-- 1枚あたり価格 -->
            <tr class="border-b border-gray-100 bg-white">
              <th scope="row" class="sticky left-0 z-10 bg-white text-left px-4 py-3 text-gray-600 font-medium whitespace-nowrap border-r border-gray-200">
                1枚あたり
              </th>
              {products.map(product => {
                const perLens = Math.ceil(product.price / product.boxCount);
                const minPerLens = Math.min(...products.map(p => Math.ceil(p.price / p.boxCount)));
                return (
                  <td class:list={[
                    'px-4 py-3 text-center font-semibold',
                    perLens === minPerLens ? 'text-green-700' : 'text-gray-700',
                  ]}>
                    約¥{perLens}
                  </td>
                );
              })}
            </tr>

            <!-- 評価 -->
            <tr class="border-b border-gray-100 bg-gray-50/30">
              <th scope="row" class="sticky left-0 z-10 bg-gray-50/60 text-left px-4 py-3 text-gray-600 font-medium whitespace-nowrap border-r border-gray-200">
                楽天評価
              </th>
              {products.map(product => (
                <td class="px-4 py-3 text-center">
                  <div class="flex flex-col items-center gap-0.5">
                    <StarRating rating={product.rating} size="sm" />
                    <span class="text-xs text-gray-400">{product.reviewCount.toLocaleString()}件</span>
                  </div>
                </td>
              ))}
            </tr>

            <!-- BC -->
            <tr class="border-b border-gray-100 bg-white">
              <th scope="row" class="sticky left-0 z-10 bg-white text-left px-4 py-3 text-gray-600 font-medium whitespace-nowrap border-r border-gray-200">
                ベースカーブ
              </th>
              {products.map(product => (
                <td class="px-4 py-3 text-center text-gray-800">{product.specs.bc}</td>
              ))}
            </tr>

            <!-- DIA -->
            <tr class="border-b border-gray-100 bg-gray-50/30">
              <th scope="row" class="sticky left-0 z-10 bg-gray-50/60 text-left px-4 py-3 text-gray-600 font-medium whitespace-nowrap border-r border-gray-200">
                直径 (DIA)
              </th>
              {products.map(product => (
                <td class="px-4 py-3 text-center text-gray-800">{product.specs.dia} mm</td>
              ))}
            </tr>

            <!-- 含水率 -->
            <tr class="border-b border-gray-100 bg-white">
              <th scope="row" class="sticky left-0 z-10 bg-white text-left px-4 py-3 text-gray-600 font-medium whitespace-nowrap border-r border-gray-200">
                含水率
              </th>
              {products.map(product => (
                <td class="px-4 py-3 text-center text-gray-800">{product.specs.water}</td>
              ))}
            </tr>

            <!-- UVカット -->
            <tr class="border-b border-gray-100 bg-gray-50/30">
              <th scope="row" class="sticky left-0 z-10 bg-gray-50/60 text-left px-4 py-3 text-gray-600 font-medium whitespace-nowrap border-r border-gray-200">
                UVカット
              </th>
              {products.map(product => (
                <td class="px-4 py-3 text-center">
                  {product.specs.uv
                    ? <span class="inline-flex items-center gap-1 text-green-700 font-semibold"><span aria-hidden="true">✓</span> あり</span>
                    : <span class="text-gray-400">なし</span>
                  }
                </td>
              ))}
            </tr>

            <!-- 素材 -->
            <tr class="border-b border-gray-100 bg-white">
              <th scope="row" class="sticky left-0 z-10 bg-white text-left px-4 py-3 text-gray-600 font-medium whitespace-nowrap border-r border-gray-200">
                素材
              </th>
              {products.map(product => (
                <td class="px-4 py-3 text-center text-gray-700 text-xs leading-snug">
                  {product.specs.material ?? '—'}
                </td>
              ))}
            </tr>

            <!-- 交換サイクル -->
            <tr class="border-b border-gray-100 bg-gray-50/30">
              <th scope="row" class="sticky left-0 z-10 bg-gray-50/60 text-left px-4 py-3 text-gray-600 font-medium whitespace-nowrap border-r border-gray-200">
                交換サイクル
              </th>
              {products.map(product => (
                <td class="px-4 py-3 text-center text-gray-700 text-xs">
                  {product.specs.replacementCycle}
                </td>
              ))}
            </tr>

            <!-- 購入ボタン行 -->
            <tr class="bg-white">
              <th scope="row" class="sticky left-0 z-10 bg-white text-left px-4 py-4 text-gray-600 font-medium whitespace-nowrap border-r border-gray-200">
                購入
              </th>
              {products.map(product => (
                <td class="px-4 py-4 text-center">
                  <RakutenButton url={product.rakutenUrl} label="楽天で買う" size="sm" />
                </td>
              ))}
            </tr>
          </tbody>
        </table>
      </div>

      <p class="text-xs text-gray-400 mt-3 text-center">
        ← 横スクロールで全商品を比較できます / 価格は楽天市場での参考価格です（変動あり）
      </p>
    </div>
  </section>

  <!-- 各商品へのリンク -->
  <section class="py-8 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-lg font-bold text-gray-900 mb-4">各商品の詳細を見る</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {products.map(product => (
          <a
            href={`${base}/products/${product.slug}/`}
            class="flex items-center gap-3 bg-white rounded-xl p-3 border border-gray-200 hover:border-blue-300 hover:shadow-sm transition-all"
          >
            <img
              src={product.image}
              alt={product.name}
              width="60"
              height="45"
              loading="lazy"
              class="w-14 h-10 object-cover rounded-lg flex-shrink-0"
            />
            <div class="min-w-0">
              <p class="text-sm font-semibold text-gray-900 truncate">{product.name}</p>
              <p class="text-xs text-blue-600">¥{product.price.toLocaleString()} / {product.boxCount}枚</p>
            </div>
            <svg class="w-4 h-4 text-gray-400 flex-shrink-0 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
