---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryCard from '../components/CategoryCard.astro';
import ProductCard from '../components/ProductCard.astro';
import { categories } from '../data/categories';
import { getPopularProducts, getProductsByCategory } from '../data/products';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const popularProducts = getPopularProducts();
---

<BaseLayout
  title="コンタクトレンズ比較ナビ"
  description="ワンデー・2週間・カラコン・乱視用・遠近両用のコンタクトレンズを徹底比較。楽天最安値・口コミ・スペック情報をわかりやすく解説します。"
>
  <!-- ヒーローセクション -->
  <section class="bg-gradient-to-br from-blue-800 to-blue-600 text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-blue-200 text-sm font-medium mb-3 tracking-widest uppercase">Contact Lens Guide</p>
      <h1 class="text-3xl md:text-5xl font-extrabold mb-5 leading-tight">
        あなたに合った<br />コンタクトレンズが<br class="md:hidden" />見つかる
      </h1>
      <p class="text-blue-100 text-lg md:text-xl mb-8 leading-relaxed">
        ワンデーから遠近両用まで。<br class="md:hidden" />
        スペック・口コミ・価格を徹底比較。<br />
        楽天市場の最安値でお得に購入できます。
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        {categories.map(cat => (
          <a
            href={`${base}/category/${cat.id}/`}
            class="bg-white/20 hover:bg-white/30 backdrop-blur text-white text-sm font-medium px-4 py-2 rounded-full transition-colors"
          >
            {cat.icon} {cat.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 安心・信頼バッジ -->
  <section class="bg-blue-50 border-b border-blue-100 py-4 px-4">
    <div class="max-w-6xl mx-auto flex flex-wrap justify-center gap-6 text-sm text-blue-800 font-medium">
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        主要メーカー全品対応
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        楽天口コミ情報掲載
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
        安全な楽天経由購入
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 5a2 2 0 012-2h10a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V5zm11 1H6v8l4-2 4 2V6z" clip-rule="evenodd"/></svg>
        スペック詳細比較あり
      </span>
    </div>
  </section>

  <!-- カテゴリセクション -->
  <section class="py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl font-bold text-gray-900 mb-2">カテゴリから探す</h2>
      <p class="text-gray-500 mb-8">あなたの目的・ライフスタイルに合ったカテゴリを選んでください。</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {categories.map(cat => (
          <CategoryCard
            category={cat}
            productCount={getProductsByCategory(cat.id).length}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- 人気商品セクション -->
  <section class="py-12 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-2xl font-bold text-gray-900">人気商品ランキング</h2>
        <span class="text-sm text-gray-400">※楽天口コミ・評価数より</span>
      </div>
      <p class="text-gray-500 mb-8">口コミ件数・高評価で選ばれた人気コンタクトレンズ。</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 relative">
        {popularProducts.map((product, i) => (
          <div class="relative">
            <!-- ランキングバッジ -->
            <span class:list={[
              'absolute -top-3 -left-3 z-10 w-8 h-8 rounded-full flex items-center justify-center text-sm font-extrabold shadow',
              i === 0 ? 'bg-yellow-400 text-yellow-900' :
              i === 1 ? 'bg-gray-300 text-gray-700' :
              i === 2 ? 'bg-orange-400 text-orange-900' :
              'bg-blue-100 text-blue-800',
            ]}>
              {i + 1}
            </span>
            <ProductCard product={product} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 選び方ガイド -->
  <section class="py-12 px-4 bg-blue-50">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">コンタクトレンズの選び方</h2>
      <div class="space-y-5">
        {[
          {
            step: '1',
            title: 'ライフスタイルで交換サイクルを選ぶ',
            body: '忙しい方・旅行が多い方はケア不要のワンデー、コスパ重視の方は2週間タイプがおすすめです。',
          },
          {
            step: '2',
            title: '視力の状態で種類を選ぶ',
            body: '乱視がある方は乱視用（トーリック）、老眼が出てきた方は遠近両用（マルチフォーカル）を選びましょう。',
          },
          {
            step: '3',
            title: '含水率・酸素透過性を確認する',
            body: 'ドライアイ気味の方は高含水または酸素透過性の高いシリコーンハイドロゲル素材がおすすめです。',
          },
          {
            step: '4',
            title: '眼科で処方を受ける',
            body: 'コンタクトレンズは高度管理医療機器です。必ず眼科医の処方・指示に従ってご使用ください。',
            warning: true,
          },
        ].map(item => (
          <div class:list={[
            'flex gap-4 p-5 rounded-xl',
            item.warning ? 'bg-amber-50 border border-amber-200' : 'bg-white',
          ]}>
            <span class:list={[
              'flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold',
              item.warning ? 'bg-amber-400 text-white' : 'bg-blue-600 text-white',
            ]}>
              {item.step}
            </span>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">{item.title}</h3>
              <p class="text-sm text-gray-600 leading-relaxed">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
